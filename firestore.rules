rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny Catches-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Security Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity validation schema blueprints
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.category is string && data.category.size() <= 100
        && data.sizes is list && data.sizes.size() <= 10
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 200
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.status is string && data.status in ['pending', 'completed']
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Rules for products catalog (Public catalog readable to anyone)
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Only manageable through GCP console
    }

    // Rules for customer transaction orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidOrder(incoming()) && incoming().createdAt == existing().createdAt && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'customerPhone'])
      );
      allow delete: if false;
    }
  }
}
